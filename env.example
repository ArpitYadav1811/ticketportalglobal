# ============================================
# Database Configuration
# ============================================
# 
# For Development:
# Use DATABASE_URL_DEV for development database
# Or use DATABASE_URL as fallback
# Note: connect_timeout=30 helps with Neon cold starts and network timeouts
DATABASE_URL_DEV=postgresql://user:password@dev-host:5432/dev_database?sslmode=require&connect_timeout=30

# For Production:
# Use DATABASE_URL_PROD for production database
# Or use DATABASE_URL as fallback
# Note: connect_timeout=30 helps with Neon cold starts and network timeouts
DATABASE_URL_PROD=postgresql://user:password@prod-host:5432/prod_database?sslmode=require&connect_timeout=30

# Fallback (used if DATABASE_URL_DEV or DATABASE_URL_PROD not set)
# This will be used in both environments if specific env vars are not set
# Note: connect_timeout=30 helps with Neon cold starts and network timeouts
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require&connect_timeout=30

# ============================================
# NextAuth Configuration
# ============================================
AUTH_SECRET=your-generated-secret-here-minimum-32-characters

# NextAuth URLs
NEXTAUTH_URL=http://localhost:4000
NEXTAUTH_URL_INTERNAL=http://localhost:4000

# ============================================
# Microsoft SSO Configuration (Optional)
# ============================================
MICROSOFT_CLIENT_ID=your-client-id-from-azure-portal
MICROSOFT_CLIENT_SECRET=your-client-secret-from-azure-portal
MICROSOFT_TENANT_ID=common

# ============================================
# File Storage Configuration
# ============================================
# Option 1: Vercel Blob Storage (Recommended - if deploying on Vercel)
# Get token from: Vercel Dashboard → Your Project → Storage → Blob → Create Token
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_FSYDkzPUyJ3lrZBK_2tkQC2VB8PNKDSvnCUKrZyLlWV5a5M

# Option 2: Supabase Storage
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_STORAGE_BUCKET=ticket-attachments

# Option 3: Cloudflare R2 (Original)
# R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=your-access-key
# R2_SECRET_ACCESS_KEY=your-secret-key
# R2_BUCKET_NAME=your-bucket-name
# R2_PUBLIC_URL=https://your-public-url.com

# Option 4: Local Storage (Development only - no config needed)
# Files will be stored in public/uploads/attachments/

# ============================================
# Environment
# ============================================
# Set to 'production' when deploying
# NODE_ENV=production
